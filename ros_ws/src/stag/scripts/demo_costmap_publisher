#!/usr/bin/env python3
from __future__ import annotations

import argparse
import time

import numpy as np
import rclpy
from nav_msgs.msg import OccupancyGrid
from rclpy.node import Node


class DemoCostmapPublisher(Node):
    def __init__(self, rover_name: str, period_sec: float) -> None:
        super().__init__("stag_demo_costmap_publisher")
        self._publisher = self.create_publisher(OccupancyGrid, f"/{rover_name}/costmap", 1)
        self._period_sec = float(period_sec)
        self._timer = self.create_timer(self._period_sec, self._publish_costmap)
        self._publish_costmap()

    def _publish_costmap(self) -> None:
        width = 96
        height = 96
        values = np.full((height, width), 100, dtype=np.int8)
        values[45:51, 10:86] = 10
        values[10:86, 45:51] = 25
        values[34:62, 34:62] = 0
        values[20:34, 62:76] = 45

        message = OccupancyGrid()
        message.header.stamp = self.get_clock().now().to_msg()
        message.header.frame_id = "map"
        message.info.map_load_time = message.header.stamp
        message.info.resolution = 0.1
        message.info.width = width
        message.info.height = height
        message.info.origin.orientation.w = 1.0
        message.data = values.ravel().astype(int).tolist()
        self._publisher.publish(message)


def main() -> None:
    parser = argparse.ArgumentParser(description="Publish a synthetic costmap for STAG demos.")
    parser.add_argument("--rover-name", default="rover")
    parser.add_argument("--period-sec", type=float, default=1.0)
    args = parser.parse_args()

    rclpy.init()
    node = DemoCostmapPublisher(args.rover_name, args.period_sec)
    try:
        rclpy.spin(node)
    except KeyboardInterrupt:
        pass
    finally:
        node.destroy_node()
        time.sleep(0.05)
        rclpy.shutdown()


if __name__ == "__main__":
    main()
